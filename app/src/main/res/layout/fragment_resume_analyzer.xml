<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <!-- ========================= -->
    <!-- MAIN SCROLLABLE CONTENT -->
    <!-- ========================= -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:padding="16dp"
        android:paddingBottom="110dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ========================= -->
            <!-- HEADER -->
            <!-- ========================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Resume Analyzer"
                android:textColor="#0B2346"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="22dp"
                android:text="Upload your CV to get a score, skill extraction, and personalized job matches"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"/>

            <!-- ========================= -->
            <!-- RESUME UPLOAD CARD -->
            <!-- ========================= -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/uploadCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#0B2346"
                app:cardCornerRadius="22dp"
                app:cardElevation="6dp"
                app:strokeColor="#183B6B"
                app:strokeWidth="1dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <!-- PDF ICON -->

                    <ImageView
                        android:id="@+id/pdfIcon"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_cv"
                        app:tint="@android:color/white"/>

                    <!-- FILE DETAILS -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/pdfIcon"
                        android:layout_marginStart="14dp"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/fileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RESUME.pdf"
                            android:textColor="@android:color/white"
                            android:textSize="17sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/uploadDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Uploaded 14/05/2026"
                            android:textColor="#B8C7D9"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <!-- ACTION BUTTONS -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            app:cardBackgroundColor="#10335E"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">

                            <ImageButton
                                android:id="@+id/btnRefresh"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:padding="10dp"
                                android:src="@drawable/ic_refresh"
                                app:tint="#42A5F5"
                                android:contentDescription="Refresh list"/>

                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="10dp"
                            app:cardBackgroundColor="#3B1630"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">

                            <ImageButton
                                android:id="@+id/btnDelete"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:padding="10dp"
                                android:src="@drawable/ic_trash"
                                app:tint="#EF5350"
                                tools:ignore="TouchTargetSizeCheck"
                                android:contentDescription="Delete item"/>

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </RelativeLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ========================= -->
            <!-- AI SCORE CARD -->
            <!-- ========================= -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="22dp"
                app:cardElevation="5dp"
                app:strokeColor="#ECECEC"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <!-- SCORE CIRCLE -->

                    <FrameLayout
                        android:layout_width="110dp"
                        android:layout_height="110dp">

                        <ProgressBar
                            android:id="@+id/scoreProgress"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:indeterminate="false"
                            android:max="100"
                            android:progress="57"
                            android:rotation="-90"
                            android:progressDrawable="@drawable/circular_progress"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/scoreValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="57"
                                android:textColor="#F59E0B"
                                android:textSize="28sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fair"
                                android:textColor="#6B7280"
                                android:textSize="12sp"/>

                        </LinearLayout>

                    </FrameLayout>

                    <!-- SCORE DETAILS -->

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Resume Score"
                            android:textColor="#111827"
                            android:textSize="20sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/scoreText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="Your resume scores 57/100. There’s room to improve."
                            android:textColor="#6B7280"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/statusLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/status_bg"
                            android:paddingLeft="12dp"
                            android:paddingTop="5dp"
                            android:paddingRight="12dp"
                            android:paddingBottom="5dp"
                            android:text="Fair"
                            android:textColor="#F59E0B"
                            android:textSize="12sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ========================= -->
            <!-- SKILLS -->
            <!-- ========================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="12dp"
                android:text="Extracted Skills"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/skillsFlexbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:flexWrap="wrap">

                <!-- SAMPLE SKILL -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:background="@drawable/skill_chip_bg"
                    android:paddingLeft="14dp"
                    android:paddingTop="8dp"
                    android:paddingRight="14dp"
                    android:paddingBottom="8dp"
                    android:text="Ethical Hacking"
                    android:textColor="#2196F3"
                    android:textSize="13sp"/>

            </com.google.android.flexbox.FlexboxLayout>

            <!-- ========================= -->
            <!-- STRENGTHS -->
            <!-- ========================= -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="#ECFDF3"
                app:cardCornerRadius="22dp"
                app:strokeColor="#C8E6C9"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅ Strengths"
                        android:textColor="#16A34A"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:lineSpacingExtra="6dp"
                        android:text="• Clear and readable format&#10;• Good variety of technical skills&#10;• Relevant educational background"
                        android:textColor="#374151"
                        android:textSize="14sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ========================= -->
            <!-- IMPROVEMENTS -->
            <!-- ========================= -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="#FFF7ED"
                app:cardCornerRadius="22dp"
                app:strokeColor="#FED7AA"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠ Areas to Improve"
                        android:textColor="#F59E0B"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:lineSpacingExtra="6dp"
                        android:text="• Add measurable impact to projects&#10;• Include more industry keywords&#10;• Add a professional summary"
                        android:textColor="#374151"
                        android:textSize="14sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ========================= -->
            <!-- AI SUGGESTIONS -->
            <!-- ========================= -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="22dp"
                app:cardElevation="4dp"
                app:strokeColor="#ECECEC"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡 AI Suggestions"
                        android:textColor="#111827"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:lineSpacingExtra="8dp"
                        android:text="1. Quantify your achievements with numbers and metrics&#10;&#10;2. Add more action verbs to work experience&#10;&#10;3. Include a professional summary at the top&#10;&#10;4. Tailor resume to each job description"
                        android:textColor="#4B5563"
                        android:textSize="14sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ========================= -->
            <!-- RECOMMENDED JOBS -->
            <!-- ========================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recommended Jobs"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/jobsRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:listitem="@layout/item_job"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ========================= -->
    <!-- BOTTOM NAVIGATION -->
    <!-- ========================= -->

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/white"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>