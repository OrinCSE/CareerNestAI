<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Logo, Title, and Match Percentage -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.cardview.widget.CardView
                android:id="@+id/companyLogoCard"
                android:layout_width="50dp"
                android:layout_height="50dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#00BFA5"> <!-- Pathao Green -->
                <TextView
                    android:id="@+id/tvLogoText"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="PA"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/companyLogoCard"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvJobTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mobile App Developer Intern"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCompanyName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pathao"
                    android:textColor="#2F80ED"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvMatchPercentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_match_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="50%"
                android:textColor="#FF9800"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Tags Row: Onsite, Level, Duration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag_light_blue"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="onsite"
                android:textColor="#2F80ED"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_tag_light_orange"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Intermediate"
                android:textColor="#FF9800"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Location, Days, and Salary Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dhaka, Bangladesh"
                android:textColor="#888888"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvSalary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="BDT 15,000/month"
                android:textColor="#00BFA5"
                android:textStyle="bold"
                android:textSize="12sp" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#EEEEEE" />

        <!-- Missing Skills Row -->
        <TextView
            android:id="@+id/tvMissingSkills"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Missing: React Native, REST APIs"
            android:textColor="#FF9800"
            android:textSize="12sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>