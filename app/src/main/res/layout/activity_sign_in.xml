<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:orientation="vertical">

    <!-- TOP SECTION -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.38"
        android:paddingHorizontal="28dp"
        android:paddingTop="26dp">

        <!-- BACK BUTTON -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:contentDescription="Go back"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <!-- Decorative Circle -->
        <View
            android:layout_width="210dp"
            android:layout_height="210dp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="-50dp"
            android:layout_marginEnd="-60dp"
            android:alpha="0.08"
            android:background="@drawable/circle_shape" />

        <!-- Decorative Circle -->
        <View
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="120dp"
            android:layout_marginEnd="120dp"
            android:alpha="0.05"
            android:background="@drawable/circle_shape" />

        <!-- TITLE -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="30dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome Back"
                android:textColor="#E5E7EB"
                android:textSize="18sp"
                android:textStyle="normal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Sign in!"
                android:textColor="@android:color/white"
                android:textSize="38sp"
                android:textStyle="bold" />

        </LinearLayout>

    </RelativeLayout>

    <!-- FORM CARD -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.62"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="34dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="false">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:paddingTop="34dp"
                android:paddingBottom="24dp">

                <!-- HEADER -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Login to your account"
                    android:textColor="#111827"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Continue your internship journey with AI-powered career support."
                    android:textColor="#6B7280"
                    android:textSize="14sp" />

                <!-- EMAIL LABEL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:text="Email Address"
                    android:textColor="#374151"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- EMAIL INPUT -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:boxBackgroundColor="#F9FAFB"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusBottomEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxStrokeColor="#2563EB"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/email_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="example@gmail.com"
                        android:inputType="textEmailAddress"
                        android:paddingVertical="16dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:textSize="15sp"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- PASSWORD LABEL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="Password"
                    android:textColor="#374151"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- PASSWORD INPUT -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundColor="#F9FAFB"
                        app:boxBackgroundMode="filled"
                        app:boxCornerRadiusBottomEnd="18dp"
                        app:boxCornerRadiusBottomStart="18dp"
                        app:boxCornerRadiusTopEnd="18dp"
                        app:boxCornerRadiusTopStart="18dp"
                        app:boxStrokeColor="#2563EB"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/password_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="Enter your password"
                            android:inputType="textPassword"
                            android:paddingVertical="16dp"
                            android:paddingEnd="50dp"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF"
                            android:textSize="15sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- CUSTOM EYE ICON -->
                    <ImageView
                        android:id="@+id/eye_icon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:contentDescription="Toggle Password"
                        android:focusable="true"
                        android:src="@drawable/ic_eye_visible"
                        tools:ignore="TouchTargetSizeCheck" />

                </RelativeLayout>
                <!-- FORGOT PASSWORD -->
                <TextView
                    android:id="@+id/tv_forgot_password"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="12dp"
                    android:text="Forgot Password?"
                    android:textColor="#2563EB"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- SIGN IN BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_signin_submit"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="30dp"
                    android:text="SIGN IN"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/crimson_primary"
                    app:cornerRadius="18dp"
                    app:elevation="2dp" />

                <!-- DIVIDER -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        android:text="OR"
                        android:textColor="#9CA3AF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB" />

                </LinearLayout>

                <!-- GOOGLE BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_google"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:text="Continue with Google"
                    android:textAllCaps="false"
                    android:textColor="#111827"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="#FFFFFF"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_google"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp" />

                <!-- SIGN UP -->
                <TextView
                    android:id="@+id/tv_goto_signup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="28dp"
                    android:text="Don't have an account? Sign up"
                    android:textColor="#6B7280"
                    android:textSize="14sp" />

            </LinearLayout>

        </ScrollView>

    </androidx.cardview.widget.CardView>

</LinearLayout>