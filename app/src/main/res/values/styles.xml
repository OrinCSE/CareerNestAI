<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="filterBtn">
        <item name="android:background">@drawable/filter_unselected</item>
        <item name="android:textColor">#555555</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
    </style>

    <style name="filterBtnSelected">
        <item name="android:background">@drawable/filter_selected</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
    </style>
    <style name="tagStyle">
        <item name="android:background">@drawable/bg_tag</item>
        <item name="android:textColor">#555</item>
        <item name="android:textSize">12sp</item>
        <item name="android:padding">6dp</item>
        <item name="android:layout_marginEnd">6dp</item>
    </style>

    <style name="tagOrange">
        <item name="android:background">@drawable/bg_tag_orange</item>
        <item name="android:textColor">#FF8800</item>
        <item name="android:textSize">12sp</item>
        <item name="android:padding">6dp</item>
        <item name="android:layout_marginEnd">6dp</item>
    </style>
    <style name="tagGray">
        <item name="android:background">@drawable/tag_gray</item>
        <item name="android:textColor">#374151</item>
        <item name="android:padding">6dp</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:textSize">12sp</item>
    </style>

</resources>