<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Light background -->
    <solid android:color="#F2F8FF"/>

    <!-- DOTTED BORDER -->
    <stroke
        android:width="2dp"
        android:color="#9EC9F5"
        android:dashWidth="10dp"
        android:dashGap="6dp"/>

    <!-- Rounded corners -->
    <corners android:radius="16dp"/>

    <!-- Inner spacing (IMPORTANT) -->
    <padding
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="16dp"/>

</shape>